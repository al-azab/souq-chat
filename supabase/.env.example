# ═══════════════════════════════════════════════════════
# SouqChat — Supabase Edge Function Secrets
# ═══════════════════════════════════════════════════════
# تُضاف عبر: supabase secrets set KEY=VALUE
# أو: Supabase Dashboard → Project Settings → Edge Functions
# ═══════════════════════════════════════════════════════

# ── مطلوب: WhatsApp Cloud API ───────────────────────────
# System User Access Token من Meta Business Manager
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxx

# App Secret لتحقق توقيع webhook
WA_APP_SECRET=your_app_secret_here

# Business Account ID (الحساب الأب الذي يملك WABAs)
WA_BUSINESS_ID=314437023701205

# إصدار Graph API
WA_API_VERSION=v24.0

# Verify Token — سلسلة سرية تختارها أنت
# يجب أن تطابق ما أدخلته في Meta Developer Portal
WA_WEBHOOK_VERIFY_TOKEN=choose_a_long_random_string_here

# ── اختياري: Cloudinary ─────────────────────────────────
# الصيغة: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=cloudinary://123456:abcdef@your_cloud

# ── اختياري: Seafile (أرشيف وسائط ذاتي الاستضافة) ──────
SEAFILE_URL=https://seafile.yourdomain.com
SEAFILE_TOKEN=your_seafile_api_token
SEAFILE_REPO_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── تلقائية (لا تُضبط يدويًا) ──────────────────────────
# SUPABASE_URL              (auto-injected)
# SUPABASE_ANON_KEY         (auto-injected)
# SUPABASE_SERVICE_ROLE_KEY (auto-injected)

# ═══════════════════════════════════════════════════════
# طريقة النشر السريع:
#   supabase secrets set \
#     WA_ACCESS_TOKEN=EAAxx \
#     WA_APP_SECRET=xx \
#     WA_BUSINESS_ID=314437023701205 \
#     WA_WEBHOOK_VERIFY_TOKEN=my_secret_token
# ═══════════════════════════════════════════════════════
